# Problema 2: Registro de Ventas de una Tienda

# 1. Crear la matriz 3x3 (puedes ajustar los valores según necesites)
# Fila = Vendedor, Columna = Día
ventas = [
    [10000, 15000, 12000], # Vendedor 0
    [30000, 35000, 40000], # Vendedor 1
    [5000, 8000, 10000]    # Vendedor 2
]

totales_por_vendedor = []
mejor_vendedor = -1
max_ventas = -1

# 2. Calcular el total de ventas de cada vendedor (suma por fila)
for i in range(len(ventas)):
    suma_vendedor = 0
    for venta in ventas[i]:
        suma_vendedor += venta
    
    totales_por_vendedor.append(suma_vendedor)
    
    # 3. Identificar el vendedor con el mayor total
    if suma_vendedor > max_ventas:
        max_ventas = suma_vendedor
        mejor_vendedor = i

    # 4. Mostrar alerta si el total es menor a $30.000
    if suma_vendedor < 30000:
        print(f"Alerta: El vendedor {i} tiene un bajo desempeño con un total de ${suma_vendedor}")

# Mostrar resultados finales
print("-" * 30)
print(f"El mejor vendedor fue el número {mejor_vendedor} con un total de ${max_ventas}")